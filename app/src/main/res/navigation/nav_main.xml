<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main.xml"
    app:startDestination="@id/activity_transfer">

    <fragment
        android:id="@+id/activity_transfer"
        android:name="com.drake.serialize.sample.ui.fragment.ActivityTransferFragment"
        android:label="Actvity传递数据"
        tools:layout="@layout/fragment_activity_transfer" />
    <fragment
        android:id="@+id/fragment_transfer"
        android:name="com.drake.serialize.sample.ui.fragment.FragmentTransferFragment"
        android:label="Fragment传递数据"
        tools:layout="@layout/fragment_transfer" />
    <fragment
        android:id="@+id/serialize"
        android:name="com.drake.serialize.sample.ui.fragment.SerializeFragment"
        android:label="读写本地数据"
        tools:layout="@layout/fragment_serialize" />
    <fragment
        android:id="@+id/view_model"
        android:name="com.drake.serialize.sample.ui.fragment.ViewModelFragment"
        android:label="配置变更恢复数据"
        tools:layout="@layout/fragment_view_model" />
    <fragment
        android:id="@+id/state_view_model"
        android:name="com.drake.serialize.sample.ui.fragment.StateViewModelFragment"
        android:label="意外销毁恢复数据"
        tools:layout="@layout/fragment_view_model" />
</navigation>